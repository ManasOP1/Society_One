# SocietyOne Admin Console (Next.js)

# Same-origin proxy — requests go to /api/v1 on this app, Next rewrites to Nest.
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Nest API URL for the Next.js dev proxy (admin/next.config.ts rewrites).
API_PROXY_TARGET=http://localhost:4000

# Production: point directly at your deployed API instead of the proxy.
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1
