# SocietyOne Admin Console (Next.js)

# Browser calls same-origin /api/v1 — Next.js rewrites proxy to Nest (dev + Vercel).
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Nest API URL for the Next.js proxy (next.config.ts rewrites).
# Local:
API_PROXY_TARGET=http://localhost:4000

# Vercel production — set in Vercel Dashboard → Settings → Environment Variables:
# NEXT_PUBLIC_API_BASE_URL=/api/v1
# API_PROXY_TARGET=https://YOUR-SERVICE.onrender.com
#
# Also on Render API, set CORS_ORIGINS to your Vercel URL, e.g.:
# CORS_ORIGINS=https://your-admin.vercel.app
