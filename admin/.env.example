# SocietyOne Admin Console (Next.js)

# Browser calls same-origin /api/v1 — Next.js rewrites proxy to Nest (dev + Vercel).
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Nest API URL for the Next.js proxy (next.config.ts rewrites).
# Local:
API_PROXY_TARGET=http://localhost:4000

# Vercel production — faster: call Render API directly (skip Vercel proxy hop):
# NEXT_PUBLIC_API_BASE_URL=https://admin-society-one.onrender.com/api/v1
# CORS_ORIGINS on Render must include your Vercel admin URL.
#
# Or keep same-origin proxy:
# NEXT_PUBLIC_API_BASE_URL=/api/v1
# API_PROXY_TARGET=https://admin-society-one.onrender.com
