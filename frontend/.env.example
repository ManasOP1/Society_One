# SocietyOne mobile app configuration.
# Copy to .env and fill in.

# Base URL of the SocietyOne Nest API, including the /api/v1 prefix.
#   Physical device (Expo Go) on the same LAN: http://<your-computer-LAN-IP>:4000/api/v1
#   Web / same machine as the API:             http://localhost:4000/api/v1
#   Android emulator (AVD):                    http://10.0.2.2:4000/api/v1
#   iOS simulator (same machine as the API):    http://localhost:4000/api/v1
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.239:4000/api/v1

# Set to "true" to force the in-app mock backend (no live data). Defaults to
# "false" — a missing/unreachable API URL is a hard error, not a silent
# fallback to fake data.
EXPO_PUBLIC_USE_MOCK=false
