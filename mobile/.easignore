# EAS Build upload ignore — keep Gradle/native caches out of the tarball
# (Windows often locks android/.gradle/*.lock and breaks compress/upload)

# Never upload local native projects — EAS runs expo prebuild on Linux.
# Local android/ may contain Windows-only paths (org.gradle.java.home).
android/

android/.gradle/
**/.gradle/
android/app/build/
android/build/
android/.cxx/
**/.cxx/
*.lock

# Local / tooling junk
.expo/
dist/
web-build/
coverage/
*.log
.env
.env.*
!.env.example

# Heavy / unused
node_modules/
**/node_modules/
