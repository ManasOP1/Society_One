{
  "cli": {
    "version": ">= 21.0.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.14.0",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://admin-society-one.onrender.com/api/v1",
        "EXPO_PUBLIC_USE_MOCK": "false"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "22.14.0",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://admin-society-one.onrender.com/api/v1",
        "EXPO_PUBLIC_USE_MOCK": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.14.0",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://admin-society-one.onrender.com/api/v1",
        "EXPO_PUBLIC_USE_MOCK": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
