model Receipt {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  societyId   String   @map("society_id") @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
