  modeCode    String   @map("mode_code") @db.VarChar(32)
  utr         String?
  bank        String?
  collectedBy String?  @map("collected_by")
  billingMonth String  @map("billing_month") @db.VarChar(7)
  pdfUrl      String?  @map("pdf_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String?  @map("created_by_id") @db.Uuid
  updatedById String?  @map("updated_by_id") @db.Uuid
  deletedById String?  @map("deleted_by_id") @db.Uuid
  rowVersion  Int      @default(1) @map("row_version")

  society Society @relation(fields: [societyId], references: [id], onDelete: Restrict)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@unique([societyId, receiptNo])
  @@index([tenantId, societyId, billingMonth])
  @@index([societyId, memberId])
  @@map("receipts")
}

