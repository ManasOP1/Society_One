# SocietyOne API — copy to .env and fill in real values

NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
APP_PUBLIC_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081,http://YOUR_LAN_IP:8081,http://YOUR_LAN_IP:3000

# Supabase Postgres (URI from Dashboard → Database → Connection string)
# Must be postgresql:// — do NOT use prisma+postgres://
# Production: use Session pooler (port 5432) — NOT the transaction pooler (6543) with Prisma.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# pg connection pool (per API instance — keep total under Supabase pool limit ~15–20)
DB_POOL_MAX=10
DB_POOL_IDLE_MS=30000
DB_POOL_CONN_TIMEOUT_MS=30000

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Redis (BullMQ background jobs — PDF, notifications, billing)
# Local:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
# Upstash (use TCP endpoint from dashboard — NOT the REST URL):
# REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR-ENDPOINT.upstash.io:6379
# Or:
# REDIS_HOST=YOUR-ENDPOINT.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=YOUR_UPSTASH_PASSWORD
# REDIS_TLS=true

# Supabase Storage (secret/service role — NEVER expose to browsers)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
# Newer dashboard name also accepted:
# SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_STORAGE_BUCKET=societyone-docs

# Razorpay — leave DISABLED until after deploy, then set RAZORPAY_ENABLED=true
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Rate limiting (Nest Throttler — per IP, rolling window)
# Development defaults to 600 req/min; production defaults to 120 req/min unless overridden.
THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=600

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@societyone.app

# WhatsApp provider (optional)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
